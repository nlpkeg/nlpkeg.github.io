---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHead from '../components/PageHead.astro';
import PublicationsByYear from '../components/PublicationsByYear.astro';

const pubs = await getCollection('publications');
const latest = Math.max(...pubs.map((p) => p.data.year));
---

<BaseLayout lang="zh" title="论文">
  <PageHead kicker="Publications" title="论文" />
  <PublicationsByYear lang="zh" year={latest} />
</BaseLayout>
