---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHead from '../../components/PageHead.astro';
import { SITE } from '../../config';
---

<BaseLayout lang="en" title="Join Us">
  <PageHead kicker="Join Us" title="Join Us" subtitle="We recruit PhD/Master students and interns to explore the knowledge inside large models" />
  <section class="sec"><div class="wrap card">
    <p>We are always looking for students passionate about <strong>LLM knowledge mechanisms, knowledge editing, retrieval augmentation, reasoning and agents</strong>. Email us with your CV and representative work.</p>
    <ul>
      <li>PhD / Master students (via UCAS admission)</li>
      <li>Research interns (remote or on-site)</li>
      <li>Visiting scholars and collaborations</li>
    </ul>
    <div class="links">
      <a href={SITE.github} target="_blank" rel="noopener">GitHub · nlpkeg</a>
      <a href={SITE.huggingface} target="_blank" rel="noopener">HuggingFace · NLPKE</a>
      <a href="mailto:shizhu.he@ia.ac.cn">shizhu.he@ia.ac.cn</a>
    </div>
  </div></section>
</BaseLayout>

<style>
  .sec { padding: 20px 0 90px; }
  .card { background: var(--panel); border: 1px solid var(--line); border-radius: var(--radius); padding: 34px; }
  .card p { color: var(--muted); margin-bottom: 16px; }
  .card strong { color: var(--ink); }
  .card ul { color: var(--muted); margin: 0 0 20px 18px; }
  .card li { margin-bottom: 8px; }
  .links { display: flex; gap: 14px; flex-wrap: wrap; }
  .links a { font-family: var(--font-display); font-size: 13.5px; color: var(--accent); border: 1px solid var(--line); border-radius: 8px; padding: 8px 14px; }
  .links a:hover { border-color: var(--accent); }
</style>
