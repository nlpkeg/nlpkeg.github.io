---
import { render, type CollectionEntry } from 'astro:content';
import { type Lang } from '../i18n/ui';
import { localizedPath } from '../i18n/utils';

interface Props { lang: Lang; entry: CollectionEntry<'news'> }
const { lang, entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const fmt = d.date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<article class="article">
  <div class="wrap">
    <a class="back" href={localizedPath('/news', lang)}>← {lang === 'zh' ? '返回资讯' : 'Back to News'}</a>
    <div class="meta">
      <time datetime={d.date.toISOString()}>{fmt}</time>
      {d.tag && <span class="tag">{d.tag}</span>}
    </div>
    <h1>{d.title}</h1>
    {d.cover && <img class="cover" src={d.cover} alt={d.title} />}
    <div class="prose">
      <Content />
    </div>
  </div>
</article>

<style>
  .article { padding: 130px 0 90px; position: relative; z-index: 2; }
  .wrap { max-width: 820px; }
  .back { display: inline-block; color: var(--muted); font-size: 14px; margin-bottom: 28px; font-family: var(--font-display); }
  .back:hover { color: var(--accent); }
  .meta { display: flex; align-items: center; gap: 14px; margin-bottom: 14px; }
  time { color: var(--accent); font-family: var(--font-display); font-size: 14px; }
  .tag { font-size: 12px; color: var(--muted); border: 1px solid var(--line); border-radius: 6px; padding: 3px 10px; font-family: var(--font-display); }
  h1 { font-size: 40px; font-weight: 800; line-height: 1.2; margin-bottom: 28px; }
  .cover { width: 100%; border-radius: var(--radius); margin-bottom: 30px; border: 1px solid var(--line); }
  .prose { color: var(--ink); font-size: 17px; line-height: 1.9; }
  .prose :global(p) { margin: 0 0 1.2em; color: var(--muted); }
  .prose :global(h2) { font-size: 24px; margin: 1.4em 0 .5em; }
  .prose :global(a) { color: var(--accent); text-decoration: underline; }
  @media (max-width: 700px) { h1 { font-size: 28px; } }
</style>
