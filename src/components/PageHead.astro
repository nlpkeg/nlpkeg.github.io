---
interface Props { kicker?: string; title: string; subtitle?: string }
const { kicker, title, subtitle } = Astro.props;
---

<section class="pagehead">
  <div class="wrap">
    {kicker && <div class="k">{kicker}</div>}
    <h1>{title}</h1>
    {subtitle && <p>{subtitle}</p>}
  </div>
</section>

<style>
  .pagehead { padding: 104px 0 14px; position: relative; z-index: 2; }
  .k { color: var(--accent); font-family: var(--font-display); font-size: 13px; letter-spacing: .16em; text-transform: uppercase; }
  h1 { font-size: 40px; font-weight: 800; margin: 8px 0 6px; }
  p { color: var(--muted); font-size: 16px; max-width: 680px; }
  @media (max-width: 900px) { h1 { font-size: 30px; } .pagehead { padding-top: 92px; } }
</style>
