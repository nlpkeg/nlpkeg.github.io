---
// Animated knowledge-graph / neural-network hero background.
// Renders only for themes that opt in (--hero-network: 1, i.e. constellation).
---

<canvas id="neural-net" aria-hidden="true"></canvas>

<style>
  #neural-net { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; }
</style>

<script>
  const c = document.getElementById('neural-net') as HTMLCanvasElement | null;
  if (c) {
    const enabled =
      getComputedStyle(document.documentElement).getPropertyValue('--hero-network').trim() === '1';
    if (!enabled) {
      c.style.display = 'none';
    } else {
      const x = c.getContext('2d')!;
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let W = 0, H = 0;
      let nodes: { x: number; y: number; vx: number; vy: number; r: number }[] = [];

      // Colors come from theme tokens so the canvas adapts to dark/light mode.
      let nodeColor = '#9be9ff', lineRGB = '54,214,255', glowRGB = '54,214,255';
      function readColors() {
        const cs = getComputedStyle(document.documentElement);
        nodeColor = cs.getPropertyValue('--net-node').trim() || nodeColor;
        lineRGB = cs.getPropertyValue('--net-line-rgb').trim() || lineRGB;
        glowRGB = cs.getPropertyValue('--net-glow-rgb').trim() || glowRGB;
      }
      readColors();
      window.addEventListener('nlpke:modechange', () => {
        readColors();
        if (prefersReduced) draw(); // repaint once when animation is paused
      });

      function init() {
        nodes = [];
        const n = Math.min(70, Math.floor(W / 22));
        for (let i = 0; i < n; i++)
          nodes.push({
            x: Math.random() * W, y: Math.random() * H,
            vx: (Math.random() - 0.5) * 0.35, vy: (Math.random() - 0.5) * 0.35,
            r: Math.random() * 2 + 1.2,
          });
      }
      function resize() {
        W = c!.width = c!.offsetWidth;
        H = c!.height = c!.offsetHeight || 700;
        init();
      }
      function draw() {
        x.clearRect(0, 0, W, H);
        for (let i = 0; i < nodes.length; i++) {
          const a = nodes[i];
          a.x += a.vx; a.y += a.vy;
          if (a.x < 0 || a.x > W) a.vx *= -1;
          if (a.y < 0 || a.y > H) a.vy *= -1;
          for (let j = i + 1; j < nodes.length; j++) {
            const b = nodes[j];
            const dx = a.x - b.x, dy = a.y - b.y, d = Math.hypot(dx, dy);
            if (d < 150) {
              x.strokeStyle = `rgba(${lineRGB},${(1 - d / 150) * 0.22})`;
              x.lineWidth = 0.7;
              x.beginPath(); x.moveTo(a.x, a.y); x.lineTo(b.x, b.y); x.stroke();
            }
          }
        }
        for (const a of nodes) {
          const g = x.createRadialGradient(a.x, a.y, 0, a.x, a.y, a.r * 4);
          g.addColorStop(0, `rgba(${glowRGB},.9)`);
          g.addColorStop(1, `rgba(${glowRGB},0)`);
          x.fillStyle = g; x.beginPath(); x.arc(a.x, a.y, a.r * 4, 0, 7); x.fill();
          x.fillStyle = nodeColor; x.beginPath(); x.arc(a.x, a.y, a.r, 0, 7); x.fill();
        }
        if (!prefersReduced) requestAnimationFrame(draw);
      }
      window.addEventListener('resize', resize);
      resize();
      draw();
    }
  }
</script>
